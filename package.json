{
  "name": "zotero-arxiv-workflow",
  "type": "module",
  "version": "0.3.6",
  "description": "arXiv Workflow for Zotero",
  "config": {
    "addonName": "arXiv Workflow for Zotero",
    "addonID": "arxiv@allanchain.github.com",
    "addonRef": "arxiv-workflow",
    "addonInstance": "arXivWorkflow",
    "prefsPrefix": "extensions.zotero.arxiv-workflow"
  },
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": "eslint --fix",
    "*.{ts,js,mjs,css,xhtml,md,yml,json}": "prettier -w"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AllanChain/zotero-arxiv-workflow.git"
  },
  "author": "Allan Chain",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/AllanChain/zotero-arxiv-workflow/issues"
  },
  "homepage": "https://github.com/AllanChain/zotero-arxiv-workflow#readme",
  "dependencies": {
    "diff": "^8.0.3",
    "p-queue": "^8.1.1",
    "zotero-plugin-toolkit": "^5.1.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^9.39.3",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.11.0",
    "@zotero-plugin/eslint-config": "^0.6.7",
    "chai": "^6.2.2",
    "eslint": "^9.39.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "zotero-plugin-scaffold": "^0.8.3",
    "zotero-types": "^4.1.1"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  },
  "packageManager": "npm@11.11.0+sha512.f36811c4aae1fde639527368ae44c571d050006a608d67a191f195a801a52637a312d259186254aa3a3799b05335b7390539cf28656d18f0591a1125ba35f973"
}
