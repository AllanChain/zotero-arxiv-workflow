{
  "name": "zotero-arxiv-workflow",
  "type": "module",
  "version": "0.3.7",
  "description": "arXiv Workflow for Zotero",
  "config": {
    "addonName": "arXiv Workflow for Zotero",
    "addonID": "arxiv@allanchain.github.com",
    "addonRef": "arxiv-workflow",
    "addonInstance": "arXivWorkflow",
    "prefsPrefix": "extensions.zotero.arxiv-workflow"
  },
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": "eslint --fix",
    "*.{ts,js,mjs,css,xhtml,md,yml,json}": "prettier -w"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AllanChain/zotero-arxiv-workflow.git"
  },
  "author": "Allan Chain",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/AllanChain/zotero-arxiv-workflow/issues"
  },
  "homepage": "https://github.com/AllanChain/zotero-arxiv-workflow#readme",
  "dependencies": {
    "diff": "^9.0.0",
    "p-queue": "^8.1.1",
    "zotero-plugin-toolkit": "^5.1.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.13.2",
    "@zotero-plugin/eslint-config": "^0.6.9",
    "chai": "^6.2.2",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "mocha": "^11.7.6",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "zotero-plugin-scaffold": "^0.8.7",
    "zotero-types": "^4.1.2"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  },
  "packageManager": "npm@11.18.0+sha512.4faecce0be70366d1c67b1012c4adc1246354a6cc45bf589f92003073b05518d547403df1475c542d67a4845e22b4fafcd7cac0af02c7a96cc6814f09eb003fb"
}
